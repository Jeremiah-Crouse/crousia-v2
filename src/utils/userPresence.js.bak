export function getRandomColor() {
  const colors = [
    '#ef4444', // red
    '#3b82f6', // blue
    '#10b981', // green
    '#f59e0b', // amber
    '#8b5cf6', // purple
    '#ec4899', // pink
  ];

  return colors[Math.floor(Math.random() * colors.length)];
}

export function getUserInfo() {
  return {
    name: 'User-' + Math.floor(Math.random() * 1000),
    color: getRandomColor(),
  };
}
