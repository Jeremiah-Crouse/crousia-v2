import { WebsocketProvider } from 'y-websocket';
import { IndexeddbPersistence } from 'y-indexeddb';
import * as Y from 'yjs';

let doc = null;
let provider = null;
let persistence = null;

export const getSharedDoc = () => {
  if (!doc) {
    doc = new Y.Doc();
  }
  return doc;
};

export const getSharedProvider = () => {
  if (!provider) {
    doc = getSharedDoc();

    // Start with connect: false so IndexedDB loads before WebSocket syncs.
    provider = new WebsocketProvider('ws://localhost:1234', 'crousia-shared-room', doc, { connect: false });

    persistence = new IndexeddbPersistence('crousia-shared-room', doc);

    persistence.on('synced', () => {
        console.log('--- Yjs Content loaded from IndexedDB ---');

        // Mark the provider as synced so the CollaborationPlugin bootstraps
        // its binding. Without this, the plugin waits for a WebSocket
        // 'sync' event that may never come (e.g. server offline), leaving
        // the binding empty and preventing text from reaching the Y.Doc.
        //
        // setTimeout ensures the CollaborationPlugin's useEffect has run
        // and registered its provider.on('sync') listener before we emit.
        setTimeout(() => {
          if (provider && !provider.synced) {
            provider.synced = true;
          }
          if (provider) {
            provider.connect();
          }
        }, 0);
    });

    provider.on('status', event => {
      console.log('--- Yjs Provider status:', event.status);
    });
  }
  return provider;
};

export const clearSharedData = async () => {
  if (persistence) {
    await persistence.clearData();
  }
  if (doc) {
    doc.destroy();
    doc = null;
    provider = null;
    persistence = null;
  }
  window.location.reload();
};

if (typeof window !== 'undefined') {
  getSharedProvider();
}
